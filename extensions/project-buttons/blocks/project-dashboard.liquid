<div id="project-dashboard-root">
  <h2>Project Dashboard</h2>
  <button id="create-board-btn">+ Create New Board</button>

  <div id="project-list-container">
    <p>Loading projects...</p>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const BACKEND_API_URL = 'https://shopify-projects-app.onrender.com/api'; 
    const shopDomain = Shopify.shop || window.location.hostname;
    const container = document.getElementById('project-list-container');
    const customerId = "{{ customer.id }}".trim();

    async function fetchProjects() {
      if (!customerId) {
        container.innerHTML = '<p>Please log in to view your projects.</p>';
        return;
      }

      try {
        const response = await fetch(`${BACKEND_API_URL}/projects?shop=${shopDomain}&customer_id=${customerId}`);
        if (!response.ok) throw new Error('Fetch failed');
        
        const data = await response.json();
        container.innerHTML = '';

        if (!data.projects || data.projects.length === 0) {
          container.innerHTML = '<p>No projects found. Create one to get started.</p>';
          return;
        }

        // Standard unstyled list output
        const ul = document.createElement('ul');
        data.projects.forEach(project => {
          const li = document.createElement('li');
          li.textContent = `${project.name} (Updated: ${new Date(project.updatedAt).toLocaleDateString()})`;
          ul.appendChild(li);
        });
        container.appendChild(ul);

      } catch (error) {
        container.innerHTML = '<p style="color: red;">Error connecting to server.</p>';
      }
    }

    const createBtn = document.getElementById('create-board-btn');
    if (createBtn) {
      createBtn.addEventListener('click', async function() {
        const name = prompt("Project Name:");
        if (!name) return;

        try {
          const res = await fetch(`${BACKEND_API_URL}/projects?shop=${shopDomain}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: name, customer_id: customerId })
          });
          if (res.ok) fetchProjects();
        } catch (err) {
          console.error('Error creating project:', err);
        }
      });
    }

    fetchProjects();
  });
</script>

{% schema %}
{
  "name": "Project Dashboard",
  "target": "section",
  "settings": []
}
{% endschema %}