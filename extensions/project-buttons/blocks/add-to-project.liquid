<div class="tile-project-wrapper" style="margin: 20px 0;">
  {% if customer %}
    <button id="openProjectModalBtn" class="button button--secondary" 
            data-customer-id="{{ customer.id }}"
            data-product-handle="{{ product.handle }}"
            style="width: 100%; padding: 12px; font-weight: bold; cursor: pointer;">
      Add to Project
    </button>
  {% else %}
    <a href="/account/login" class="button" style="display: block; text-align: center; text-decoration: none; padding: 12px;">
      Log in to Add to Project
    </a>
  {% endif %}
</div>

<div id="projectModal" style="display: none; position: fixed; z-index: 9999; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.5); align-items: center; justify-content: center;">
  <div style="background: white; padding: 30px; border-radius: 8px; width: 90%; max-width: 450px; box-shadow: 0 4px 20px rgba(0,0,0,0.15); position: relative; font-family: sans-serif;">
    
    <span id="closeProjectModal" style="position: absolute; right: 20px; top: 15px; font-size: 24px; cursor: pointer; color: #666;">&times;</span>
    
    <h3 style="margin-top: 0; margin-bottom: 20px; color: #333;">Add Product to Project</h3>
    
    <div id="modalLoadingState" style="display: block; text-align: center; padding: 20px 0;">
      <p style="color: #666;">Loading your projects...</p>
    </div>

    <div id="modalMainState" style="display: none;">
      <div id="existingProjectsGroup" style="margin-bottom: 20px;">
        <label for="projectSelect" style="display: block; margin-bottom: 8px; font-weight: bold; color: #444;">Select Project:</label>
        <select id="projectSelect" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-size: 14px;">
        </select>
      </div>

      <div id="newProjectGroup" style="margin-bottom: 20px; display: none;">
        <label for="newProjectName" style="display: block; margin-bottom: 8px; font-weight: bold; color: #444;">New Project Name:</label>
        <input type="text" id="newProjectName" placeholder="e.g., Master Bathroom Floor" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; font-size: 14px;">
      </div>

      <button id="confirmAddBtn" class="button" style="width: 100%; padding: 12px; background: #000; color: #fff; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;">
        Confirm & Save Item
      </button>
    </div>

    <div id="modalStatusMessage" style="display: none; margin-top: 15px; padding: 10px; text-align: center; border-radius: 4px; font-size: 14px;"></div>
  </div>
</div>

<script>
  // 1. MASTER REGISTRY: Pre-compile every single variant + its unique metafields into a JavaScript lookup dictionary
  const shopifyVariantRegistry = {
    {% for variant in product.variants %}
      "{{ variant.id }}": {
        productTitle: "{{ product.title | escape }}",
        variantTitle: "{{ variant.title | escape }}",
        priceFormatted: "{{ variant.price | money }}",
        thumbnailUrl: "{{ variant.featured_image | default: product.featured_image | img_url: '240x240' }}",
        pRating: "{{ variant.metafields.custom.p_rating.value | default: 'N/A' | escape }}",
        // ✅ CRITICAL FIX: The variant SKU is now actively mapped and captured on every load!
        sku: "{{ variant.sku | escape }}"
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  };

  // Helper function to extract whatever variant ID the storefront is actively showing
  function getActiveVariantId() {
    const hiddenInput = document.querySelector('form[action*="/cart/add"] input[name="id"]');
    if (hiddenInput && hiddenInput.value) return hiddenInput.value;

    const urlParams = new URLSearchParams(window.location.search);
    const urlVariant = urlParams.get('variant');
    if (urlVariant) return urlVariant;

    return "{{ product.selected_or_first_available_variant.id }}";
  }

  document.addEventListener('DOMContentLoaded', function() {
    const openBtn = document.getElementById('openProjectModalBtn');
    const modal = document.getElementById('projectModal');
    const closeBtn = document.getElementById('closeProjectModal');
    const confirmBtn = document.getElementById('confirmAddBtn');
    
    const loadingState = document.getElementById('modalLoadingState');
    const mainState = document.getElementById('modalMainState');
    const existingGroup = document.getElementById('existingProjectsGroup');
    const newGroup = document.getElementById('newProjectGroup');
    
    const projectSelect = document.getElementById('projectSelect');
    const newProjectInput = document.getElementById('newProjectName');
    const statusDiv = document.getElementById('modalStatusMessage');

    let customerId = openBtn ? openBtn.getAttribute('data-customer-id') : null;
    let productHandle = openBtn ? openBtn.getAttribute('data-product-handle') : null;
    let userProjects = [];

    if (!openBtn) return;

    // Open Modal Action
    openBtn.addEventListener('click', function() {
      modal.style.display = 'flex';
      loadingState.style.display = 'block';
      mainState.style.display = 'none';
      statusDiv.style.display = 'none';
      
      fetch(`/apps/projects/api/projects/${customerId}`)
        .then(res => res.json())
        .then(data => {
          userProjects = Array.isArray(data) ? data : [];
          populateDropdown(userProjects);
          loadingState.style.display = 'none';
          mainState.style.display = 'block';
        })
        .catch(err => {
          console.error("Failed fetching user projects:", err);
          loadingState.innerText = "Error loading your workspace projects.";
        });
    });

    closeBtn.addEventListener('click', () => modal.style.display = 'none');
    window.addEventListener('click', (e) => { if (e.target === modal) modal.style.display = 'none'; });

    projectSelect.addEventListener('change', function() {
      if (this.value === 'NEW_PROJECT') {
        newGroup.style.display = 'block';
      } else {
        newGroup.style.display = 'none';
      }
    });

    function populateDropdown(projects) {
      projectSelect.innerHTML = '';
      if (projects.length === 0) {
        const opt = document.createElement('option');
        opt.value = 'NEW_PROJECT';
        opt.innerText = 'Create a New Project...';
        projectSelect.appendChild(opt);
        newGroup.style.display = 'block';
      } else {
        projects.forEach(proj => {
          const opt = document.createElement('option');
          opt.value = proj.id;
          opt.innerText = proj.project_name;
          projectSelect.appendChild(opt);
        });
        const dividerOpt = document.createElement('option');
        dividerOpt.value = 'NEW_PROJECT';
        dividerOpt.innerText = '+ Create a New Project...';
        projectSelect.appendChild(dividerOpt);
        newGroup.style.display = 'none';
      }
    }

    confirmBtn.addEventListener('click', function() {
      const isNew = projectSelect.value === 'NEW_PROJECT';
      const selectedProjectId = isNew ? null : projectSelect.value;
      const newName = isNew ? newProjectInput.value.trim() : null;

      if (isNew && !newName) {
        showStatus('Please name your new project.', 'red');
        return;
      }

      // Capture the LIVE selected variant ID right now at the precise moment of submission
      const activeVariantId = getActiveVariantId();
      // Pull the exact, matching specifications snapshot out of our registry
      const activeVariantMetadata = shopifyVariantRegistry[activeVariantId] || {
        productTitle: "{{ product.title | escape }}",
        variantTitle: "Selected Variant",
        priceFormatted: "N/A",
        thumbnailUrl: "{{ product.featured_image | img_url: '240x240' }}",
        pRating: "N/A",
        sku: "{{ product.selected_or_first_available_variant.sku | escape }}" // Added fallback SKU safety
      };

      showStatus('Saving item...', 'blue');

      const payload = {
        customerId: customerId,
        projectId: selectedProjectId,
        newProjectName: newName,
        variantId: activeVariantId,
        productHandle: productHandle,
        variantInfo: activeVariantMetadata 
      };

      fetch('/apps/projects/api/projects/add-item', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
      .then(res => res.json())
      .then(resData => {
        if (resData.success) {
          showStatus('✨ Added to project successfully!', 'green');
          newProjectInput.value = '';
          setTimeout(() => { modal.style.display = 'none'; }, 1500);
        } else {
          showStatus('Error: ' + (resData.error || 'Unable to save.'), 'red');
        }
      })
      .catch(err => {
        console.error("Critical submission failure:", err);
        showStatus('Network delivery failed.', 'red');
      });
    });

    function showStatus(msg, color) {
      statusDiv.style.display = 'block';
      statusDiv.innerText = msg;
      if (color === 'green') {
        statusDiv.style.background = '#e6f4ea';
        statusDiv.style.color = '#137333';
      } else if (color === 'red') {
        statusDiv.style.background = '#fce8e6';
        statusDiv.style.color = '#c5221f';
      } else {
        statusDiv.style.background = '#e8f0fe';
        statusDiv.style.color = '#1a73e8';
      }
    }
  });
</script>

{% schema %}
{
  "name": "Add to Project Button",
  "target": "section",
  "templates": ["product"],
  "settings": []
}
{% endschema %}