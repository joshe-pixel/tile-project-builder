{% if customer %}
  <button id="ep-trigger-modal-btn" type="button" class="button" style="width: 100%; margin-top: 10px; background: #fff; border: 1px solid #000; color: #000; padding: 12px; font-weight: bold; cursor: pointer;">
    Add to Project
  </button>
{% else %}
  <a href="/account/login" class="button" style="width: 100%; display: block; text-align: center; margin-top: 10px; background: #fff; border: 1px solid #000; color: #000; padding: 12px; font-weight: bold; text-decoration: none; box-sizing: border-box;">
    Log In to Save to Project
  </a>
{% endif %}

<div id="epProjectModal" style="display: none; position: fixed; z-index: 999999; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); align-items: center; justify-content: center; font-family: sans-serif;">
  <div style="background: #fff; padding: 30px; border-radius: 8px; width: 90%; max-width: 460px; box-shadow: 0 4px 25px rgba(0,0,0,0.15); position: relative; box-sizing: border-box;">
    <span id="ep-close-modal-span" style="position: absolute; right: 20px; top: 15px; font-size: 24px; cursor: pointer; color: #666;">&times;</span>
    
    <h3 style="margin: 0 0 20px 0; font-size: 18px; font-weight: bold; color: #000;">Add Material to Project</h3>
    
    <div style="display: flex; flex-direction: column; gap: 16px;">
      <div>
        <label style="display: block; font-size: 12px; font-weight: bold; margin-bottom: 6px;">Select Project Board</label>
        <select id="ep-project-select" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; background: #fff; font-size: 14px;">
          <option value="">Loading project boards...</option>
        </select>
        <input type="text" id="ep-new-project-input" placeholder="Enter New Project Name..." style="display: none; width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; margin-top: 8px; font-size: 14px; box-sizing: border-box;">
      </div>

      <div id="ep-section-wrapper" style="display: none;">
        <label style="display: block; font-size: 12px; font-weight: bold; margin-bottom: 6px;">Select Room/Area</label>
        <select id="ep-section-select" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; background: #fff; font-size: 14px;">
          <option value="">-- Choose Room/Area --</option>
        </select>
        <input type="text" id="ep-new-section-input" placeholder="Enter New Room/Area Name..." style="display: none; width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; margin-top: 8px; font-size: 14px; box-sizing: border-box;">
      </div>

      <button type="button" id="ep-submit-add-btn" style="width: 100%; padding: 12px; background: #000; color: #fff; border: 1px solid #000; border-radius: 4px; font-weight: bold; cursor: pointer; text-transform: uppercase; margin-top: 10px; letter-spacing: 0.5px;">
        Add to Project
      </button>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const triggerBtn = document.getElementById('ep-trigger-modal-btn');
  const modal = document.getElementById('epProjectModal');
  const closeModal = document.getElementById('ep-close-modal-span');
  const projectSelect = document.getElementById('ep-project-select');
  const sectionSelect = document.getElementById('ep-section-select');
  const newProjInput = document.getElementById('ep-new-project-input');
  const newSecInput = document.getElementById('ep-new-section-input');
  const sectionWrapper = document.getElementById('ep-section-wrapper');
  const submitBtn = document.getElementById('ep-submit-add-btn');

  let workspaceCachedData = [];
  const customerId = "{{ customer.id }}";

  if (!triggerBtn) return;

  // 🔄 Trigger Modal: Open Frame and Fetch Live User Datasets
  triggerBtn.addEventListener('click', function() {
    modal.style.display = 'flex';
    fetchProjectsJson();
  });

  closeModal.addEventListener('click', function() { modal.style.display = 'none'; });
  modal.addEventListener('click', function(e) { if(e.target === modal) modal.style.display = 'none'; });

  function fetchProjectsJson() {
    fetch('/apps/projects/api/projects-json?customer_id=' + customerId)
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          workspaceCachedData = data.workspace || [];
          populateProjectsDropdown();
        }
      });
  }

  function populateProjectsDropdown() {
    projectSelect.innerHTML = '<option value="">-- Choose Existing Project --</option>';
    workspaceCachedData.forEach(proj => {
      const opt = document.createElement('option');
      opt.value = proj.id;
      opt.textContent = proj.project_name;
      projectSelect.appendChild(opt);
    });
    const createOpt = document.createElement('option');
    createOpt.value = "__CREATE_NEW__";
    createOpt.textContent = "[+ Create New Project]";
    projectSelect.appendChild(createOpt);
  }

  // 🔄 Watch Project Dropdown Selections
  projectSelect.addEventListener('change', function() {
    const val = this.value;
    newProjInput.style.display = 'none';
    newSecInput.style.display = 'none';
    sectionSelect.innerHTML = '<option value="">-- Choose Room/Area --</option>';
    
    if (val === "__CREATE_NEW__") {
      newProjInput.style.display = 'block';
      sectionWrapper.style.display = 'block';
      populateSectionsDropdown([]); // No existing sections for a brand new project
    } else if (val) {
      sectionWrapper.style.display = 'block';
      const selectedProj = workspaceCachedData.find(p => p.id === val);
      populateSectionsDropdown(selectedProj ? selectedProj.sections : []);
    } else {
      sectionWrapper.style.display = 'none';
    }
  });

  function populateSectionsDropdown(sections) {
    sectionSelect.innerHTML = '<option value="">-- Choose Existing Room/Area --</option>';
    sections.forEach(sec => {
      const opt = document.createElement('option');
      opt.value = sec.id;
      opt.textContent = sec.section_name;
      sectionSelect.appendChild(opt);
    });
    const createOpt = document.createElement('option');
    createOpt.value = "__CREATE_NEW__";
    createOpt.textContent = "[+ Create New Room/Area]";
    sectionSelect.appendChild(createOpt);
  }

  sectionSelect.addEventListener('change', function() {
    newSecInput.style.display = (this.value === "__CREATE_NEW__") ? 'block' : 'none';
  });

  // 🚀 Form Dispatch Processing Core Pipeline
  submitBtn.addEventListener('click', async function() {
    let targetProjectId = projectSelect.value;
    let targetSectionId = sectionSelect.value;

    if (!targetProjectId) return alert("Please select or create a project board.");
    if (!targetSectionId) return alert("Please select or create a room/area.");

    submitBtn.innerText = "ADDING...";
    submitBtn.disabled = true;

    try {
      // 1. Check if we need to create a new project first
      if (targetProjectId === "__CREATE_NEW__") {
        const newProjName = newProjInput.value.trim();
        if (!newProjName) throw new Error("Please enter a new project name.");

        const resProj = await fetch('/apps/projects/api/projects', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: newProjName, customer_id: customerId })
        }).then(r => r.json());

        if (!resProj.success) throw new Error("Failed to generate new project board container.");
        targetProjectId = resProj.data[0].id;
      }

      // 2. Check if we need to create a new section/room
      if (targetSectionId === "__CREATE_NEW__") {
        const newSecName = newSecInput.value.trim();
        if (!newSecName) throw new Error("Please enter a room/area name.");

        const resSec = await fetch('/apps/projects/api/sections/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ projectId: targetProjectId, sectionName: newSecName })
        }).then(r => r.json());

        if (!resSec.success) throw new Error("Failed to generate row layout component.");
        targetSectionId = resSec.sectionId;
      }

      // 3. Collect active product profile dimensions
      const variantId = window.ShopifyAnalytics.meta.product.variants[0].id || "{{ product.selected_or_first_available_variant.id }}";
      const productHandle = "{{ product.handle }}";
      
      const variantInfo = {
        productTitle: "{{ product.title | escape }}",
        variantTitle: "{{ product.selected_or_first_available_variant.title | escape }}",
        sku: "{{ product.selected_or_first_available_variant.sku }}",
        priceFormatted: "{{ product.selected_or_first_available_variant.price | money }}",
        thumbnailUrl: "{{ product.featured_image | img_url: '240x240' }}",
        pRating: "N/A"
      };

      // 4. Inject structural record spec into target row grid
      const finalRes = await fetch('/apps/projects/api/items/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          sectionId: targetSectionId,
          variantId: variantId,
          productHandle: productHandle,
          variantInfo: variantInfo
        })
      }).then(r => r.json());

      if (finalRes.success) {
        alert("✨ Success! Material saved cleanly inside your workspace profile.");
        modal.style.display = 'none';
        window.location.reload();
      } else {
        throw new Error(finalRes.error);
      }

    } catch (err) {
      alert("❌ Save Failure: " + err.message);
    } finally {
      submitBtn.innerText = "ADD TO PROJECT";
      submitBtn.disabled = false;
    }
  });
});
</script>

{% schema %}
{
  "name": "Add to Project Trigger",
  "target": "section",
  "settings": []
}
{% endschema %}