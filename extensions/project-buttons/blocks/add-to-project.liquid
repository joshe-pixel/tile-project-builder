{%- comment -%}
  🎯 APPROVED ACCESS CONTROL LIST (ACL)
  Only users whose emails are explicitly added to this comma-separated string 
  will see the 'Add to Project' button interface on your live store.
{%- endcomment -%}
{%- assign allowed_emails_string = "alisonv@earp.com.au,joshe@earp.com.au,harryp@earp.com.au,lisap@earp.com.au,sophiem@earp.com.au,jennip@earp.com.au,richarde@earp.com.au,chloet@earp.com.au,karindam@earp.com.au,alexe@earp.com.au,ashleed@earp.com.au,judithh@earp.com.au,rachell@earp.com.au" -%}
{%- assign allowed_emails = allowed_emails_string | split: "," -%}

{% if customer and allowed_emails contains customer.email %}
<style>
  #epProjectModal input::placeholder { color: #999 !important; }
  #epProjectModal select, #epProjectModal input { box-sizing: border-box !important; }
</style>

<button type="button" id="ep-trigger-modal-btn" class="button button--secondary" 
        style="display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; padding: 12px; font-weight: bold; cursor: pointer; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 15px; background-color: #fff; color: #000; border: 1px solid #000; transition: all 0.3s ease;">
  <svg id="ep-heart-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
  </svg>
  <span id="ep-trigger-text">Add to My Project</span>
</button>

<div id="epProjectModal" style="display: none; position: fixed; z-index: 999999; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); align-items: center; justify-content: center; font-family: sans-serif;">
  <div style="background: #fff; padding: 30px; border-radius: 8px; width: 90%; max-width: 460px; box-shadow: 0 4px 25px rgba(0,0,0,0.15); position: relative; box-sizing: border-box;">
    
    <span id="ep-close-modal-span" style="position: absolute; right: 20px; top: 15px; font-size: 24px; cursor: pointer; color: #666;">&times;</span>
    
    <h3 style="margin: 0 0 20px 0; font-size: 18px; font-weight: bold; color: #000; text-transform: uppercase; letter-spacing: 0.5px;">Add to Project/Samples</h3>
    
    <div style="display: flex; flex-direction: column; gap: 16px;">
      <div>
        <label style="display: block; font-size: 12px; font-weight: bold; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px;">SELECT PROJECT</label>
        <select id="ep-project-select" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; background: #fff; font-size: 14px; box-sizing: border-box;">
          <option value="">Select/Add Project</option>
        </select>
        <input type="text" id="ep-new-project-input" placeholder="Enter New Project Name..." style="display: none; width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; margin-top: 8px; font-size: 14px; box-sizing: border-box;">
      </div>

      <div id="ep-section-wrapper" style="display: none;">
        <label style="display: block; font-size: 12px; font-weight: bold; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px;">SELECT ROOM/AREA</label>
        <select id="ep-section-select" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; background: #fff; font-size: 14px; box-sizing: border-box;">
          <option value="">Select/Add Room/Area</option>
        </select>
        <input type="text" id="ep-new-section-input" placeholder="Enter New Room/Area Name..." style="display: none; width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; margin-top: 8px; font-size: 14px; box-sizing: border-box;">
      </div>

      <button type="button" id="ep-submit-add-btn" style="width: 100%; padding: 12px; background: #000; color: #fff; border: 1px solid #000; border-radius: 4px; font-weight: bold; cursor: pointer; text-transform: uppercase; margin-top: 10px; letter-spacing: 0.5px;">
        ADD NOW
      </button>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const triggerBtn = document.getElementById('ep-trigger-modal-btn');
  const modal = document.getElementById('epProjectModal');
  const closeModal = document.getElementById('ep-close-modal-span');
  const projectSelect = document.getElementById('ep-project-select');
  const newProjectInput = document.getElementById('ep-new-project-input');
  const sectionSelect = document.getElementById('ep-section-select');
  const newSectionInput = document.getElementById('ep-new-section-input');
  const sectionWrapper = document.getElementById('ep-section-wrapper');
  const submitBtn = document.getElementById('ep-submit-add-btn');

  const productHandle = "{{ product.handle }}";
  const customerId = "{{ customer.id }}".trim(); 

  let cachedWorkspaceData = [];

  // 🎯 THE FIX: Build a comprehensive map of all variant data dynamically, including inventory checks!
  const variantDictionary = {
    {% for variant in product.variants %}
      "{{ variant.id }}": {
        title: {{ variant.title | json }},
        priceFormatted: "{{ variant.price | money }}",
        thumbnailUrl: {% if variant.image %}"{{ variant.image | img_url: '800x800' }}"{% else %}"{{ product.featured_image | img_url: '800x800' }}"{% endif %},
        sku: {{ variant.sku | json }},
        pRating: "{{ variant.metafields.technical.pendulum.value | default: variant.metafields.custom.p_rating | escape }}",
        units: "{{ variant.metafields.information.units.value | default: 'm²' | escape }}",
        boxConversion: {{ variant.metafields.technical.unitsbox.value | default: 1.0 }},
        inventoryQuantity: {{ variant.inventory_quantity | default: 0 }},
        inventoryPolicy: "{{ variant.inventory_policy | escape }}",
        leadTime: {{ variant.metafields.technical.leadtime.value | json | default: '[]' }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  };

  // Deep Text-Node Scanner for ghost colons
  setInterval(() => {
    if (modal.style.display === 'flex') {
      modal.querySelectorAll('span, div, label, option, p, a, button').forEach(el => {
        el.childNodes.forEach(node => {
          if (node.nodeType === Node.TEXT_NODE && node.nodeValue) {
            const trimmed = node.nodeValue.trim();
            if (trimmed.startsWith(':')) {
              node.nodeValue = node.nodeValue.replace(/^:\s*/, '');
            }
          }
        });
      });
    }
  }, 50);

  // Primary Button Routing Logic
  triggerBtn.addEventListener('click', function() {
    if (triggerBtn.getAttribute('data-state') === 'view-mode') {
      window.location.href = '/apps/projects';
    } else {
      modal.style.display = 'flex';
      loadProjects(); 
    }
  });

  closeModal.addEventListener('click', () => modal.style.display = 'none');
  window.addEventListener('click', (e) => { if (e.target === modal) modal.style.display = 'none'; });

  projectSelect.addEventListener('change', function() {
    if (this.value === "NEW_PROJECT") {
      newProjectInput.style.display = 'block';
      sectionWrapper.style.display = 'block';
      sectionSelect.innerHTML = '<option value="">Select/Add Room/Area</option>';
      
      const newRoomOpt = document.createElement('option');
      newRoomOpt.value = "NEW_ROOM";
      newRoomOpt.textContent = "+ Create New Room/Area...";
      sectionSelect.appendChild(newRoomOpt);
    } else if (this.value !== "") {
      newProjectInput.style.display = 'none';
      sectionWrapper.style.display = 'block';
      loadRoomsFromCache(this.value); 
    } else {
      newProjectInput.style.display = 'none';
      sectionWrapper.style.display = 'none';
    }
  });

  sectionSelect.addEventListener('change', function() {
    if (this.value === "NEW_ROOM") {
      newSectionInput.style.display = 'block';
    } else {
      newSectionInput.style.display = 'none';
    }
  });

  // Submit Action Hook
  submitBtn.addEventListener('click', function() {
    if (!customerId) {
      alert("Please log in to your account to save materials to your project boards.");
      return;
    }

    submitBtn.innerText = "ADDING...";
    submitBtn.disabled = true;

    try {
      // 🎯 Grab the active variant ID that your main-product.liquid script is syncing
      const activeVariantId = document.querySelector('input[name="id"]')?.value || 
                              document.querySelector('select[name="id"]')?.value || 
                              "{{ product.selected_or_first_available_variant.id }}";
      
      // 🎯 Pull all the correct details straight out of our variant dictionary
      const activeVariantData = variantDictionary[activeVariantId] || variantDictionary["{{ product.selected_or_first_available_variant.id }}"];

      const payload = {
        customerId: customerId,
        projectId: projectSelect.value,
        newProjectName: newProjectInput.value,
        roomId: sectionSelect.value,
        newRoomName: newSectionInput.value,
        variantId: activeVariantId,
        productHandle: productHandle,
        variantInfo: {
          productTitle: "{{ product.title | escape }}",
          variantTitle: activeVariantData.title,
          priceFormatted: activeVariantData.priceFormatted,
          thumbnailUrl: activeVariantData.thumbnailUrl,
          sku: activeVariantData.sku,
          pRating: activeVariantData.pRating,
          units: activeVariantData.units,
          boxConversion: activeVariantData.boxConversion,
          inventoryQuantity: activeVariantData.inventoryQuantity,
          inventoryPolicy: activeVariantData.inventoryPolicy,
          leadTime: activeVariantData.leadTime
        }
      };

      // Execute network transaction pipeline safely
      fetch('/apps/projects/api/projects/add-item', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
      .then(res => {
        if (!res.ok) throw new Error("HTTP App Proxy server error status: " + res.status);
        return res.json();
      })
      .then(data => {
        if (!data.success) throw new Error(data.error || "Supabase database error");
        
        modal.style.display = 'none';
        document.getElementById('ep-trigger-text').innerText = "VIEW IN PROJECT/SAMPLES";
        document.getElementById('ep-heart-icon').setAttribute('fill', 'currentColor');
        triggerBtn.setAttribute('data-state', 'view-mode');
        triggerBtn.style.background = "#000";
        triggerBtn.style.color = "#fff";
      })
      .catch(err => {
        console.error("Network endpoint catch triggered:", err);
        alert("Transaction Failed: " + err.message);
        submitBtn.innerText = "ADD NOW";
        submitBtn.disabled = false;
      })
      .finally(() => {
        if (modal.style.display === 'flex') {
          submitBtn.innerText = "ADD NOW";
          submitBtn.disabled = false;
        }
      });

    } catch (clientError) {
      console.error("Client side compilation halted:", clientError);
      alert("Frontend Script Interrupted: " + clientError.message + "\nCheck browser console for tracing metrics.");
      submitBtn.innerText = "ADD NOW";
      submitBtn.disabled = false;
    }
  });

  function handleSmartFetch(url) {
    return fetch(url)
      .then(response => response.text())
      .then(text => {
        if (text.trim().startsWith('<!DOCTYPE')) {
          throw new Error('HTML_INTERCEPTED');
        }
        return JSON.parse(text);
      });
  }

  function loadProjects() {
    handleSmartFetch('/apps/projects/api/projects-json?customer_id=' + customerId)
      .then(data => {
        projectSelect.innerHTML = '<option value="">Select/Add Project</option>';
        const workspace = data.workspace || [];
        cachedWorkspaceData = workspace; 

        if (workspace.length > 0) {
          workspace.forEach(project => {
            const option = document.createElement('option');
            option.value = project.id; 
            option.textContent = project.project_name; 
            projectSelect.appendChild(option);
          });
        }
        
        const newProjOpt = document.createElement('option');
        newProjOpt.value = "NEW_PROJECT";
        newProjOpt.textContent = "+ Create New Project...";
        projectSelect.appendChild(newProjOpt);
      })
      .catch(err => {
        console.error('Error loading projects list:', err);
        projectSelect.innerHTML = '<option value="">Error loading projects</option>';
      });
  }

  function loadRoomsFromCache(selectedProjectId) {
    sectionSelect.innerHTML = '<option value="">Select/Add Room/Area</option>';
    const activeProject = cachedWorkspaceData.find(proj => proj.id === selectedProjectId);
    
    if (activeProject && activeProject.sections && activeProject.sections.length > 0) {
      activeProject.sections.forEach(room => {
        const option = document.createElement('option');
        option.value = room.id;
        option.textContent = room.section_name; 
        sectionSelect.appendChild(option);
      });
    }
    
    const newRoomOpt = document.createElement('option');
    newRoomOpt.value = "NEW_ROOM";
    newRoomOpt.textContent = "+ Create New Room/Area...";
    sectionSelect.appendChild(newRoomOpt);
  }
});
</script>
{% endif %}

{% schema %}
{
  "name": "Add to Project Trigger",
  "target": "section",
  "settings": []
}
{% endschema %}